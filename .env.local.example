# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Personal Access Token (for `pnpm db:types`)
# Generate at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Spotify (Client Credentials flow / OAuth user flow 共用)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Spotify OAuth user flow (Phase B-1 で追加)
# 開発: http://localhost:3000/api/spotify/callback
# 本番: https://karaoke-recommender-omega.vercel.app/api/spotify/callback
SPOTIFY_REDIRECT_URI=

# トークン暗号化用 (32 バイト hex)
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# 管理者メールアドレス (/admin/* へのアクセスをこの email のみに制限)
ADMIN_EMAIL=
